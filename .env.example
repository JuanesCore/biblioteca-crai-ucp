# Copiar a .env en la raíz del frontend (solo desarrollo local).
# En AWS Amplify: Hosting → Environment variables (prefijo REACT_APP_).

# Firebase Web SDK (Console Firebase → Configuración del proyecto → Tus apps)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Backend API (URL absoluta, debe terminar en /api)
# Ejemplo: https://ec2-xx-xx-xx-xx.compute.amazonaws.com/api
REACT_APP_API_URL=
