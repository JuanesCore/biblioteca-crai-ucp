PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/academic_search?retryWrites=true&w=majority
JWT_SECRET=replace_this_with_a_long_random_value

# Firebase Admin (servidor): una de las dos opciones

# Opción A — archivo JSON de cuenta de servicio (recomendado en EC2)
# Ruta relativa al directorio backend/ o absoluta en el servidor
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json

# Opción B — variables (útil si no quieres archivo en disco)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS: orígenes del frontend (Amplify / dominio propio), separados por coma
# Ejemplo: https://main.d123abc.amplifyapp.com,https://app.ucp.edu.co
CORS_ORIGIN=http://localhost:3000

# Opcional: detrás de nginx/ALB con HTTPS
# TRUST_PROXY=1
